# ==============================================================================
# SentinelLedger AI Suite - Environment Variable Template
# Copy this file to '.env' and fill in your actual credentials.
# ==============================================================================

# --- Database Configurations (MySQL) ---
DB_HOST=your-mysql-hostname
DB_PORT=3306
DB_USER=your-database-username
DB_PASSWORD=your-database-password
DB_DATABASE=sentinelledger

# --- Proxy Routing Settings ---
# In production, these should be internal URLs if using Render Blueprint private services:
# e.g., FRAUD_BASE=http://fraudguard:5000
# e.g., SPAM_BASE=http://spamshield:5001
FRAUD_BASE=http://127.0.0.1:5000
SPAM_BASE=http://127.0.0.1:5001

# --- Django settings (SpamShield) ---
# Generate a secure, random 50-character string for production SECRET_KEY
SECRET_KEY=generate-a-secure-secret-key-for-production
DEBUG=False
# Comma-separated trusted origins (should include your public gateway Render web service URL)
# e.g., CSRF_TRUSTED_ORIGINS=https://sentinelledger-gateway.onrender.com
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
